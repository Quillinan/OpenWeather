{
  "name": "openweather",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "electron .",
    "pack": "electron-builder"
  },
  "build": {
    "productName": "OpenWeather",
    "appId": "com.example.openweather",
    "directories": {
      "output": "releases",
      "buildResources": "dist"
    },
    "files": [
      "dist/**/*",
      "electron/main.mjs",
      "node_modules"
    ],
    "nsis": {
      "uninstallDisplayName": "Uninstall OpenWeather",
      "license": "LICENSE.txt",
      "oneClick": "false",
      "allowToChangeInstallationDirectory": "true"
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "axios": "^1.6.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.1",
    "styled-components": "^6.1.1",
    "sweetalert2": "^11.10.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.3",
    "electron-builder": "^24.13.3",
    "eslint": "^8.53.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.0"
  }
}
